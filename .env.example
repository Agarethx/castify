# Database
DATABASE_URL="postgresql://castify:castify_secret@localhost:5432/castify_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# BunnyCDN
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_STORAGE_ZONE="your-storage-zone"

# Peer5
PEER5_KEY="your-peer5-key"

# Next.js public env
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_PEER5_KEY="your-peer5-key"

# Postgres container
POSTGRES_USER=castify
POSTGRES_PASSWORD=castify_secret
POSTGRES_DB=castify_db
STREAMING_SECRET=dev-secret
