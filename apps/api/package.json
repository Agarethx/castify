{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@castify/validators(.*)$": "<rootDir>/../../../packages/validators/src$1",
      "^@castify/types(.*)$": "<rootDir>/../../../packages/types/src$1",
      "^@castify/config(.*)$": "<rootDir>/../../../packages/config/src$1"
    }
  },
  "dependencies": {
    "@castify/config": "workspace:*",
    "@castify/types": "workspace:*",
    "@castify/validators": "workspace:*",
    "@fastify/multipart": "^8.3.1",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.2.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@types/passport-jwt": "^4.0.1",
    "fastify": "^5.8.4",
    "jest": "^30.3.0",
    "prisma": "^6.2.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
