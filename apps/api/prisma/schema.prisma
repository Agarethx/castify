generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChannelPlan {
  starter
  pro
  enterprise
}

enum ContentType {
  live
  vod
}

enum ContentStatus {
  draft
  published
  archived
}

enum UserRole {
  admin
  channel_admin
  viewer
}

enum AdBreakPosition {
  preroll
  midroll
  postroll
}

model Channel {
  id           String      @id @default(uuid())
  name         String
  slug         String      @unique
  logoUrl      String?
  primaryColor String      @default("#000000")
  plan         ChannelPlan @default(starter)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  users   User[]
  content Content[]

  @@map("channels")
}

model Content {
  id           String        @id @default(uuid())
  channelId    String
  title        String
  slug         String
  type         ContentType
  status       ContentStatus @default(draft)
  thumbnailUrl String?
  duration     Int?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  channel        Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  streamSessions StreamSession[]
  adBreaks       AdBreak[]

  @@unique([channelId, slug])
  @@map("contents")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(viewer)
  channelId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channel        Channel?        @relation(fields: [channelId], references: [id], onDelete: SetNull)
  streamSessions StreamSession[]

  @@map("users")
}

model StreamSession {
  id            String    @id @default(uuid())
  contentId     String
  viewerId      String?
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  p2pOffloadPct Float     @default(0)
  bytesFromPeers BigInt   @default(0)
  bytesFromCdn   BigInt   @default(0)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  viewer  User?   @relation(fields: [viewerId], references: [id], onDelete: SetNull)

  @@map("stream_sessions")
}

model AdBreak {
  id          String          @id @default(uuid())
  contentId   String
  position    AdBreakPosition
  vastUrl     String
  durationSecs Int
  createdAt   DateTime        @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("ad_breaks")
}
