generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  CHANNEL_ADMIN
  VIEWER
}

enum ContentType {
  LIVE
  VOD
}

enum ContentStatus {
  INACTIVE
  ACTIVE
  PROCESSING
  ERROR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Channel {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#000000")
  plan         Plan     @default(STARTER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users    User[]
  contents Content[]

  @@map("channels")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CHANNEL_ADMIN)
  channelId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Content {
  id          String        @id @default(uuid())
  channelId   String
  title       String
  type        ContentType   @default(LIVE)
  status      ContentStatus @default(INACTIVE)
  streamKey   String        @unique @default(uuid())
  hlsUrl      String?
  localPath   String?
  durationSec Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  channel  Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sessions StreamSession[]

  @@map("contents")
}

model StreamSession {
  id             String    @id @default(uuid())
  contentId      String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  bytesFromPeers BigInt    @default(0)
  bytesFromCdn   BigInt    @default(0)
  p2pOffloadPct  Float     @default(0)
  avgLatencyMs   Int       @default(0)
  peersConnected Int       @default(0)
  qualityChanges Int       @default(0)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("stream_sessions")
}
